#include <vector>
#include <map>
#include <memory>
#include <algorithm>
#include "Student"

class StudentManager {
private:
    map<int, shared_ptr<Student>> students; // Stockage : ID -> Etudiant

public:
    void add(shared_ptr<Student> s);        // DuplicateIDException si ID existe
    void remove(int id);                    // StudentNotFoundException si absent
    void update(int id, shared_ptr<Student> updated);

    shared_ptr<Student> findById(int id) const;
    
    // Recherche partielle : retourne tous les étudiants dont le nom CONTIENT la chaîne n
    vector<shared_ptr<Student>> findByName(const string& n) const {
        vector<shared_ptr<Student>> result;
        auto it = students.begin();
        
        while ((it = std::find_if(it, students.end(), [&n](const auto& pair) {
            // Chercher si le nom contient la chaîne n (insensible à la casse)
            string fullName = pair.second->getName();
            string searchTerm = n;
            
            // Convertir en minuscules pour comparaison insensible à la casse
            std::transform(fullName.begin(), fullName.end(), fullName.begin(), ::tolower);
            std::transform(searchTerm.begin(), searchTerm.end(), searchTerm.begin(), ::tolower);
            
            return fullName.find(searchTerm) != string::npos;
        })) != students.end()) {
            result.push_back(it->second);
            ++it;
        }
        return result;
    }

    // Tri par GPA décroissant (meilleur au moins bon)
    vector<shared_ptr<Student>> sortByGpa() const {
        vector<shared_ptr<Student>> result;
        // 1. Copier tous les étudiants dans un vecteur
        for (const auto& pair : students) {
            result.push_back(pair.second);
        }
        // 2. Trier le vecteur par GPA décroissant
        std::sort(result.begin(), result.end(), [](const shared_ptr<Student>& a, const shared_ptr<Student>& b) {
            return a->getGpa() > b->getGpa(); // ordre décroissant
        });
        return result;
    }
    // Tri alphabétique par nom, insensible à la casse
    vector<shared_ptr<Student>> sortByName() const {
        vector<shared_ptr<Student>> result;
        // 1. Copier tous les étudiants dans un vecteur
        for (const auto& pair : students) {
            result.push_back(pair.second);
        }
        // 2. Trier le vecteur par nom (alphabétique, insensible à la casse)
        std::sort(result.begin(), result.end(), [](const shared_ptr<Student>& a, const shared_ptr<Student>& b) {
            string nameA = a->getName();
            string nameB = b->getName();
            // Convertir les deux noms en minuscules pour comparaison insensible à la casse
            std::transform(nameA.begin(), nameA.end(), nameA.begin(), ::tolower);
            std::transform(nameB.begin(), nameB.end(), nameB.begin(), ::tolower);
            return nameA < nameB; // ordre alphabétique croissant
        });
        return result;
    }

    // Moyenne des GPA de tous les étudiants
    double averageGpa() const {
        if (students.empty()) return 0.0;
        double sum = 0.0;
        for (const auto& pair : students) {
            sum += pair.second->getGpa();
        }
        return sum / students.size();
    }
    
    int count() const { return students.size(); }
    
    int countByType(const string& type) const {
        return std::count_if(students.begin(), students.end(), [&type](const auto& pair) {
            // À adapter selon la méthode disponible pour obtenir le type
            return pair.second->getType() == type;
        });
    }
    const map<int, shared_ptr<Student>>& getAll() const { return students; }
};
